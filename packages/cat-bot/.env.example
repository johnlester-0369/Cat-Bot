PORT=3000
NODE_ENV=development

# Valid levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# ── Bot Management API / Better Auth ───────────────────────────────────────────
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# For web development
VITE_URL=http://localhost:5173

# Supported values: json | mongodb | neondb | (unset = prisma-sqlite default)
DATABASE_TYPE=neondb

# ── NeonDB (only used when DATABASE_TYPE=neondb) ──────────────────────────────
# ---------------------------------------------------------------------------
# Neon PostgreSQL connection string.
# Find this in the Neon Console: project → Connection Details → Connection string
#
# Format: postgres://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require
#
# Quick setup:
#   1. Create a project at https://console.neon.tech
#   2. Copy the connection string from Connection Details
#   3. Set DATABASE_TYPE=neondb in this file
#   4. Run the schema: psql $NEON_DATABASE_URL -f packages/database/adapters/neondb/src/schema.sql
#      OR call initDb() at application boot (it runs schema.sql statements automatically)
#   5. Run better-auth schema: cd packages/cat-bot && npx @better-auth/cli migrate
#
# The pool is also used directly by better-auth — no Prisma or additional ORM needed.
NEON_DATABASE_URL=postgres://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── MongoDB (only used when DATABASE_TYPE=mongodb) ────────────────────────────
# ------------------------------------------------------------------------------
# MongoDB connection URI template with <PASSWORD> placeholder
# The <PASSWORD> placeholder will be automatically replaced with MONGO_PASSWORD
#
# Format examples:
# - MongoDB Atlas: mongodb+srv://username:<PASSWORD>@cluster0.mongodb.net?retryWrites=true&w=majority
# - Local MongoDB: mongodb://username:<PASSWORD>@127.0.0.1:27017
# - Docker MongoDB: mongodb://username:<PASSWORD>@mongodb:27017
#
# Note: DO NOT include the database name in the URI - use MONGO_DATABASE_NAME instead
# Note: DO NOT URI-encode the password here - it will be automatically encoded
MONGODB_URI=mongodb+srv://username:<PASSWORD>@cluster0.mongodb.net?retryWrites=true&w=majority

# MongoDB password (will be automatically URI-encoded)
# Can contain special characters like: @ # $ % & etc.
# These will be properly encoded to prevent connection issues
MONGO_PASSWORD=your-mongodb-password

# Database name for MongoDB connections
# This is used by the MongoDB adapter (better-auth + all bot repo collections)
# If not set, will throw an error at startup — always set this when DATABASE_TYPE=mongodb
MONGO_DATABASE_NAME=catbot

# ── Telegram Webhook (optional) ─────────────────────────────────────────────────
# Set to your bare public domain (no protocol) to enable webhook mode.
# Leave unset to use long-polling (default; works without a public domain).
# TELEGRAM_WEBHOOK_DOMAIN=your-domain.com

# ── Credential Encryption ─────────────────────────────────────────────────────
# Required: AES-256-GCM symmetric key for encrypting platform credentials at rest.
# Generate a secure key with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_char_key_here
