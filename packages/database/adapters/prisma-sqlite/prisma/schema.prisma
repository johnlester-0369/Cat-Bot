generator client {
  // prisma-client is the v7 provider name; prisma-client-js is removed
  provider = "prisma-client"
  // output is required in v7 — generates the client into src/ so tsc and tsx can resolve it
  output   = "../src/generated/prisma"
  compilerBuild = "fast"
}

datasource db {
  // url is configured in prisma.config.ts in v7; schema.prisma only declares the driver
  provider = "sqlite"
}

// ── Bot Users — persists platform-specific user info captured on first encounter ──
// The userId is the unique string primary key.
// firstName, username, avatarUrl are nullable because not every platform exposes them
// (e.g. Facebook Page 1:1 returns only name; Telegram bots may lack avatar access).
model BotUser {
  platformId  Int
  id          String   @id
  name        String
  firstName   String?
  username    String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  // updatedAt tracks the last time platform API returned fresh profile data for drift detection
  updatedAt   DateTime @updatedAt

  // Implicit M:M relations populated dynamically from thread metadata
  participatingThreads BotThread[] @relation("ThreadParticipants")
  adminOfThreads       BotThread[] @relation("ThreadAdmins")
  sessions             BotUserSession[] @relation("UserSessions")
  participatingServers BotDiscordServer[] @relation("ServerParticipants")
  adminOfServers       BotDiscordServer[] @relation("ServerAdmins")

  @@map("bot_users")
}

// ── Bot Threads — persists platform-specific thread/group metadata ─────────────
// memberCount is nullable — some platforms (large Discord guilds) do not expose it.
model BotThread {
  platformId     Int
  id             String   @id
  name           String?
  isGroup        Boolean  @default(false)
  memberCount    Int?
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Implicit M:M relations connecting users to this thread
  participants BotUser[] @relation("ThreadParticipants")
  admins       BotUser[] @relation("ThreadAdmins")
  sessions     BotThreadSession[] @relation("ThreadSessions")

  @@map("bot_threads")
}

// ── Bot User Sessions — tracks which (userId, platform, sessionId) tuples ─────
// have already fetched and synced a given bot_user row.
// The composite PK acts as the unique "this session knows this user" marker:
// one row = one (session × user) pair. All four columns together are the key.
model BotUserSession {
  userId     String
  // platformId mirrors bot_users.platformId — same compact integer encoding (PLATFORM_TO_ID)
  platformId Int
  sessionId String
  botUserId String
  // Tracks the last time this (session × user) pair was refreshed from the platform API.
  // The middleware uses this to decide whether a re-fetch is needed — stale after SYNC_INTERVAL_MS (1 h).
  // @updatedAt makes Prisma auto-stamp this on every ORM update, so upsertUserSession needs no explicit field.
  lastUpdatedAt DateTime @default(now()) @updatedAt
  // JSON blob — stores named collections (e.g. "daily", "inventory") without dynamic tables.
  // Parsed and serialized entirely at the adapter layer; business logic never sees raw JSON.
  data      String?
  botUser BotUser @relation("UserSessions", fields: [botUserId], references: [id])

  @@id([userId, platformId, sessionId, botUserId])
  @@map("bot_users_session")
}

// ── Bot Thread Sessions — tracks which (userId, platform, sessionId) tuples ────
// have already fetched and synced a given bot_thread row.
// Same composite PK pattern as BotUserSession — four-column unique marker.
model BotThreadSession {
  userId       String
  platformId   Int
  sessionId   String
  botThreadId String
  // Tracks the last time this (session × thread) pair was refreshed from the platform API.
  // The middleware uses this to decide whether a re-fetch is needed — stale after SYNC_INTERVAL_MS (1 h).
  // @updatedAt makes Prisma auto-stamp this on every ORM update, so upsertThreadSession needs no explicit field.
  lastUpdatedAt DateTime @default(now()) @updatedAt
  // JSON blob — stores named collections for thread-scoped bot settings (e.g. rankup toggle, custom messages)
  // without dynamic tables. Parsed and serialized entirely at the adapter layer.
  data        String?

  botThread BotThread @relation("ThreadSessions", fields: [botThreadId], references: [id])

  @@id([userId, platformId, sessionId, botThreadId])
  @@map("bot_threads_session")
}

// ── Bot Discord Server — isolated storage for Discord guilds ─────────────────
// Discord servers contain multiple channels; storing settings purely by channel ID
// incorrectly fragments server-wide balances and admin configurations.
model BotDiscordServer {
  id             String   @id
  name           String?
  avatarUrl      String?
  memberCount    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participants   BotUser[] @relation("ServerParticipants")
  admins         BotUser[] @relation("ServerAdmins")
  channels       BotDiscordChannel[]
  sessions       BotDiscordServerSession[]

  @@map("bot_discord_server")
}

model BotDiscordChannel {
  serverId String
  threadId String @id
  server   BotDiscordServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@map("bot_discord_channel")
}

model BotDiscordServerSession {
  userId        String
  sessionId     String
  botServerId   String
  lastUpdatedAt DateTime @default(now()) @updatedAt
  data          String?

  server BotDiscordServer @relation(fields: [botServerId], references: [id], onDelete: Cascade)

  @@id([userId, sessionId, botServerId])
  @@map("bot_discord_server_session")
}

// ── Better Auth — user, session, account, verification ────────────────────────
// These four models are required by better-auth's prisma adapter. String @id
// fields use cuid2 (generated internally by better-auth) rather than autoincrement
// so IDs are portable across DB engines and safe for distributed generation.
model user {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // better-auth admin plugin: role controls /admin/* endpoint access; ban fields allow
  // admins to soft-suspend accounts without deleting rows, preserving audit history.
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      session[]
  accounts      account[]
  // Back-relations to bot credential and identity tables — required by Prisma whenever a
  // child model declares @relation pointing here; omitting them causes schema validation errors.
  botSessions                BotSession[]                     @relation("BotSessionUser")
  botAdmins                  BotAdmin[]                       @relation("BotAdminUser")
  botCredentialsDiscord      BotCredentialDiscord[]           @relation("BotCredentialDiscordUser")
  botCredentialsTelegram     BotCredentialTelegram[]          @relation("BotCredentialTelegramUser")
  botPremiums                BotPremium[]                     @relation("BotPremiumUser")
  botCredentialsFacebookPage BotCredentialFacebookPage[]      @relation("BotCredentialFacebookPageUser")
  botCredentialsFbMessenger  BotCredentialFacebookMessenger[] @relation("BotCredentialFacebookMessengerUser")
  botFbPageWebhook           FbPageWebhook?                   @relation("FbPageWebhookUser")

  @@map("user")
}

model session {
  id        String   @id
  expiresAt DateTime
  // token carries the signed session cookie value — unique enforces one active token per session row
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  // Null for all regular sessions; populated only when an admin creates an impersonation session.
  impersonatedBy String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model account {
  id                    String    @id
  // accountId + providerId together identify the OAuth account (e.g. GitHub user 12345)
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  // password stores bcrypt hash for email/password strategy — null for OAuth-only accounts
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model verification {
  id         String    @id
  // identifier is the email or phone being verified; value is the OTP/token
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt


  @@map("verification")
}

// ── Bot Session — per-session bot configuration (nickname, command prefix) ───
// Composite PK (userId, platformId, sessionId) = one config row per authenticated owner per bot session.
// userId is a String FK to better-auth's user.id (cuid2 format) — cascade-deletes when the owner account is removed.
model BotSession {
  userId     String
  platformId Int
  sessionId  String
  // nickname and prefix are optional; the bot falls back to defaults when null
  nickname   String?
  prefix     String?
  // Controls whether this session is loaded at startup — set false to take a session offline
  // without deleting credentials. The session-loader filters out isRunning = false rows at boot.
  isRunning  Boolean @default(true)
  // JSON blob — stores bot session scoped data (e.g. state, cache) without dynamic tables
  data       String?

  user user @relation("BotSessionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, platformId, sessionId])
  @@map("bot_session")
}

// ── Bot Admin — tracks which platform-native users are granted admin privileges ─
// adminId is the platform-native user ID of the elevated user (NOT a better-auth ID).
// Including adminId in the composite PK allows multiple admins per session without a surrogate key.
model BotAdmin {
  userId     String
  platformId Int
  sessionId  String
  adminId    String

  user user @relation("BotAdminUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, platformId, sessionId, adminId])
  @@map("bot_admin")
}

// ── Bot Premium — tracks which platform-native users are granted premium privileges ─
// premiumId is the platform-native user ID of the elevated user (NOT a better-auth ID).
// Including premiumId in the composite PK allows multiple premium users per session.
// Premium users inherit ANYONE + THREAD_ADMIN + PREMIUM command access but NOT BOT_ADMIN.
model BotPremium {
  userId     String
  platformId Int
  sessionId  String
  premiumId  String

  user user @relation("BotPremiumUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, platformId, sessionId, premiumId])
  @@map("bot_premium")
}


// ── Bot Credential: Discord ───────────────────────────────────────────────────
// discordToken and discordClientId are stored per-session so one owner can run
// multiple Discord bot accounts simultaneously under separate sessionIds.
model BotCredentialDiscord {
  userId          String
  platformId      Int
  sessionId       String
  discordToken    String
  discordClientId String
  // Tracks whether the slash command menu is currently registered and what command config was last deployed.
  // Prevents redundant Discord REST calls on every restart when commands haven't changed.
  isCommandRegister Boolean @default(false)
  commandHash       String?

  user user @relation("BotCredentialDiscordUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, platformId, sessionId])
  @@map("bot_credential_discord")
}

// ── Bot Credential: Telegram ──────────────────────────────────────────────────
model BotCredentialTelegram {
  userId        String
  platformId    Int
  sessionId     String
  telegramToken String
  // Tracks whether the slash command menu is currently registered and what command config was last deployed.
  // Prevents redundant Bot API calls on every restart when commands haven't changed.
  isCommandRegister Boolean @default(false)
  commandHash       String?

  user user @relation("BotCredentialTelegramUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, platformId, sessionId])
  @@map("bot_credential_telegram")
}

// ── Bot Credential: Facebook Page ─────────────────────────────────────────────
// fbPageId distinguishes which Facebook Page this token manages — one owner can
// administer multiple pages under different sessionIds.
model BotCredentialFacebookPage {
  userId        String
  platformId    Int
  sessionId     String
  fbAccessToken String
  fbPageId      String

  user user @relation("BotCredentialFacebookPageUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, platformId, sessionId])
  @@map("bot_credential_facebook_page")
}

// ── Bot Credential: Facebook Messenger ────────────────────────────────────────
// appstate holds the serialised fca-unofficial login cookie blob as a JSON string.
// Stored as TEXT in SQLite (can be several KB); never exposed in API responses or logs.
model BotCredentialFacebookMessenger {
  userId     String
  platformId Int
  sessionId  String
  appstate   String

  user user @relation("BotCredentialFacebookMessengerUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, platformId, sessionId])
  @@map("bot_credential_facebook_messenger")
}


// ── Fb Page Webhook — tracks webhook verification status per Facebook Page owner ─
// userId is the sole PK — one webhook verification record per better-auth user.
// isVerified defaults to false and is flipped to true once the hub.challenge handshake succeeds.
model FbPageWebhook {
  userId     String  @id
  isVerified Boolean @default(false)

  user user @relation("FbPageWebhookUser", fields: [userId], references: [id], onDelete: Cascade)

  @@map("fb_page_webhook")
}

// ── Bot Session Commands — per-session command enable/disable overrides ────────
// One row per (userId, platformId, sessionId, commandName) — created at bot startup
// with isEnable = true via createMany({ skipDuplicates: true }) so existing false rows
// set by the bot admin are never overwritten. Absent row = enabled (fail-open default).
model BotSessionCommand {
  userId      String
  platformId  Int
  sessionId   String
  commandName String
  // false = command blocked by bot admin; row is preserved (not deleted) so intent is visible
  isEnable    Boolean @default(true)

  @@id([userId, platformId, sessionId, commandName])
  @@map("bot_session_commands")
}

// ── Bot Session Events — per-session event module enable/disable overrides ─────
// Identical pattern to BotSessionCommand; keyed by the event module's config.name
// (e.g. 'join', 'leave') rather than the dispatch eventType ('log:subscribe').
// This makes the web dashboard labels human-readable without exposing internal keys.
model BotSessionEvent {
  userId     String
  platformId Int
  sessionId  String
  eventName  String
  isEnable   Boolean @default(true)

  @@id([userId, platformId, sessionId, eventName])
  @@map("bot_session_events")
}

// ── Bot User Session Banned — per-session user ban records ────────────────────
// isBanned defaults to true on insert — an explicit unban sets it false rather
// than deleting the row so the reason field is preserved for audit purposes.
model BotUserBanned {
  userId     String
  platformId Int
  sessionId  String
  botUserId  String
  isBanned   Boolean @default(true)
  // reason is optional so an immediate ban without an explanation is still valid
  reason     String?

  @@id([userId, platformId, sessionId, botUserId])
  @@map("bot_users_session_banned")
}

// ── Bot Thread Session Banned — per-session thread ban records ────────────────
// Mirrors BotUserBanned; keyed by botThreadId instead of botUserId.
model BotThreadBanned {
  userId      String
  platformId  Int
  sessionId   String
  botThreadId String
  isBanned    Boolean @default(true)
  reason      String?

  @@id([userId, platformId, sessionId, botThreadId])
  @@map("bot_threads_session_banned")
}

// ── System Admin — globally privileged platform-native user IDs ────────────────
// adminId is the platform-native user ID granted global system admin authority
// across all bot sessions — unlike bot_admin which is scoped per (userId, sessionId).
// @unique prevents duplicate registrations without a separate query-before-insert guard.
model SystemAdmin {
  id        String   @id @default(cuid())
  adminId   String   @unique
  createdAt DateTime @default(now())

  @@map("system_admin")
}
