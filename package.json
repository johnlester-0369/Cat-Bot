{
  "name": "cat-bot-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev -w packages/cat-bot",
    "dev:web": "npm run dev -w packages/web",
    "build:db": "npm run build -w packages/database",
    "build": "npm run build -w packages/cat-bot",
    "build:web": "npm run build -w packages/web",
    "start": "npm run start -w packages/cat-bot",
    "preview": "npm run preview -w packages/web",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "test": "npm run test -w packages/cat-bot",
    "test:watch": "npm run test:watch -w packages/cat-bot",
    "seed:admin": "npm run seed:admin -w packages/cat-bot",
    "dev:all": "concurrently -n \"bot,web\" \"npm run dev\" \"npm run dev:web\"",
    "build:all": "concurrently -n \"bot,web\" \"npm run build\" \"npm run build:web\""
  },
  "workspaces": [
    "packages/cat-bot",
    "packages/database",
    "packages/database/adapters/json",
    "packages/database/adapters/neondb",
    "packages/database/adapters/mongodb",
    "packages/web"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
